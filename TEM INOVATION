 class GetTarget {
     constructor(id) {
         this.id = id;
         this.x = -1;
         this.y = -1;
         this.prevX = Array(5).fill(-1);
         this.prevY = Array(5).fill(-1);
         this.active = false;
         this.weapon = -1;
         this.gear = -1;
     }

     update(ux, uy) {
         this.active = true;
         this.prevX = [this.x, ...this.prevX.slice(0, 4)];
         this.prevY = [this.y, ...this.prevY.slice(0, 4)];
         this.x = ux;
         this.y = uy;
     }

     setInactive() {
         this.x = -1;
         this.y = -1;
         this.prevX.fill(-1);
         this.prevY.fill(-1);
         this.active = false;
         GetAllTargets.resetLines();
     }

     historyCount() {
         let count = 0;
         for (let i = 0; i < this.prevX.length; i++) {
             if (this.prevX[i] !== -1) count++;
             else break;
         }
         return count;
     }
 }

// ================== HELPER FUNCTIONS (из первого скрипта) ==================
var _RAD2DEG = 180 / Math.PI;

function _rangeCheck(a, b, v) {
    return v <= Math.max(a, b) && v >= Math.min(a, b);
}

function lineIntersect(x1, y1, x2, y2, x3, y3, x4, y4) {
    var m1 = (y2 - y1) / (x2 - x1);
    var b1 = y1 - x1 * m1;
    var m2 = (y4 - y3) / (x4 - x3);
    var b2 = y3 - x3 * m2;
    if (x1 === x2) {
        if (x3 === x4) {
            if (x1 === x3) {
                if (_rangeCheck(y1, y2, y3)) return { x: x3, y: y3 };
                if (_rangeCheck(y1, y2, y4)) return { x: x4, y: y4 };
                if (_rangeCheck(y3, y4, y1)) return { x: x1, y: y1 };
                if (_rangeCheck(y3, y4, y2)) return { x: x2, y: y2 };
            }
            return null;
        }
        if (_rangeCheck(x3, x4, x1)) {
            var iy = m2 * x1 + b2;
            if (_rangeCheck(y3, y4, iy) && _rangeCheck(y1, y2, iy)) return { x: x1, y: iy };
            return null;
        }
    }
    if (m1 === m2) {
        if (b1 === b2) {
            if (_rangeCheck(x1, x2, x3)) return { x: x3, y: y3 };
            if (_rangeCheck(x1, x2, x4)) return { x: x4, y: y4 };
            if (_rangeCheck(x3, x4, x1)) return { x: x1, y: y1 };
            if (_rangeCheck(x3, x4, x2)) return { x: x2, y: y2 };
        }
        return null;
    }
    var ix = (b2 - b1) / (m1 - m2);
    var iy2 = m1 * ix + b1;
    if (_rangeCheck(x1, x2, ix) && _rangeCheck(x3, x4, ix)) return { x: ix, y: iy2 };
    return null;
}

function _calcDistance(p1, p2) {
    return Math.floor(Math.sqrt(Math.pow(p1.x - p2.x, 2) + Math.pow(p1.y - p2.y, 2)));
}

// ================== AIMBOT CON ==================
 class AimbotCon {
     constructor() {
         this.lastAngle = 0;
         this.targetPlayer = null;
         this.cleanAngle = 0;
         // Внутренние буферы для ультра-точного предсказания
         this._histVx = [];   // история скоростей по X
         this._histVy = [];   // история скоростей по Y
         this._histAx = [];   // история ускорений по X
         this._histAy = [];   // история ускорений по Y
         this._lastTargetId = -1;
         this._adaptCoef = 1.0;
         this._lastHitTime = 0;
         this._consecutiveHits = 0;
         this._smoothedAngle = null;
         this._lastRetargetTime = 0;
     }

     // Сброс истории при смене цели
     _resetHistory(targetId) {
         if (this._lastTargetId !== targetId) {
             this._lastTargetId = targetId;
             this._histVx = [];
             this._histVy = [];
             this._histAx = [];
             this._histAy = [];
             this._adaptCoef = 1.0;
             this._smoothedAngle = null;
             this._consecutiveHits = 0;
         }
     }

     wannaFire(watarget) {
         if (watarget === undefined) watarget = this.targetPlayer;
         if (!watarget) return false;
         if (watarget.historyCount() < 2) return false;
         var x0 = watarget.prevX[0], x1 = watarget.prevX[1];
         var y0 = watarget.prevY[0], y1 = watarget.prevY[1];
         if (x0 === -1 || x1 === -1 || y0 === -1 || y1 === -1) return false;
         return (
             ((watarget.x - x0 > 0) !== (x0 - x1 > 0)) ||
             ((watarget.y - y0 > 0) !== (y0 - y1 > 0))
         );
     }

     // ─────────────────────────────────────────────────────────────────
     // ULTRA PREDICTION V11 — ускорение + взвешенная скорость + MOD-настройки
     // distanceCoefficient: делитель расстояния → чем меньше, тем дальше целимся вперёд
     // bulletSpeedCoefficient: скорость пули → рассчитываем время полёта
     // offsetCoefficient: финальный поправочный коэф (аддитивный)
     // ─────────────────────────────────────────────────────────────────
     predictPosition(target, myX, myY) {
         const hist = target.historyCount();
         if (hist === 0) return { x: target.x, y: target.y };

         const depth = Math.min(hist + 1, 9);
         const px = new Array(depth);
         const py = new Array(depth);
         px[0] = target.x; py[0] = target.y;
         for (let i = 1; i < depth; i++) {
             px[i] = target.prevX[i - 1];
             py[i] = target.prevY[i - 1];
             if (px[i] === -1) { px.length = i; py.length = i; break; }
         }
         const n = px.length;
         if (n < 2) return { x: target.x, y: target.y };

         // Взвешенные скорости (новые кадры важнее)
         let wSumVx = 0, wSumVy = 0, wTotal = 0;
         for (let i = 0; i < n - 1; i++) {
             const w = Math.pow(0.85, i);
             wSumVx += (px[i] - px[i + 1]) * w;
             wSumVy += (py[i] - py[i + 1]) * w;
             wTotal += w;
         }
         const avgVx = wSumVx / wTotal;
         const avgVy = wSumVy / wTotal;

         // Ускорение
         let accelX = 0, accelY = 0;
         if (n >= 3) {
             let wSumAx = 0, wSumAy = 0, wTotalA = 0;
             for (let i = 0; i < n - 2; i++) {
                 const vCur  = px[i]   - px[i+1]; const vPrev  = px[i+1] - px[i+2];
                 const vCurY = py[i]   - py[i+1]; const vPrevY = py[i+1] - py[i+2];
                 const w = Math.pow(0.78, i);
                 wSumAx += (vCur - vPrev) * w; wSumAy += (vCurY - vPrevY) * w; wTotalA += w;
             }
             accelX = wSumAx / wTotalA;
             accelY = wSumAy / wTotalA;
         }

         const dist = Math.hypot(myX - target.x, myY - target.y);

         // Близкий бой: только скорость, без offsetCoefficient
         if (dist < 60) {
             const T0 = Math.max(0.05, dist / (MOD.distanceCoefficient * MOD.bulletSpeedCoefficient));
             return { x: target.x + avgVx * T0, y: target.y + avgVy * T0 };
         }

         // Стандартное предсказание
         const bulletFlightTicks = (dist / (MOD.distanceCoefficient * MOD.bulletSpeedCoefficient)) + MOD.offsetCoefficient;
         const T = Math.max(0.1, bulletFlightTicks);

         return {
             x: target.x + avgVx * T + 0.5 * accelX * T * T,
             y: target.y + avgVy * T + 0.5 * accelY * T * T
         };
     }

     // Итеративное предсказание
     predictIterative(target, myX, myY, iterations) {
         iterations = iterations || 3;
         let pred = { x: target.x, y: target.y };
         for (let iter = 0; iter < iterations; iter++) {
             pred = this.predictPosition(target, myX, myY);
         }
         return pred;
     }

     resolve(forFiring) {
         if (forFiring === undefined) forFiring = false;
         if (!World || !World.PLAYER || !World.PLAYER.id) return this.lastAngle;
         const myPlayer = GetAllTargets.getPlayerById(World.PLAYER.id);
         if (!myPlayer || !myPlayer.active) return this.lastAngle;
         let target;

         if (MOD.lockId > -1) {
             target = GetAllTargets.getPlayerById(MOD.lockId);
             if (!target || !target.active) target = null;
         }

         if (!target) {
             target = MOD.mouseFovEnable
                 ? this.findNearestPlayerTo(GetAllTargets.mouseMapCords, MOD.mouseFov)
                 : this.findNearestPlayerTo(myPlayer, 999999);
         }

         this.targetPlayer = target;
         if (!target) return null;

         this._resetHistory(target.id);

         // ═══════════════════════════════════════════════════════
         // RESOLVER TYPE SWITCH
         // ═══════════════════════════════════════════════════════

         if (MOD.resolverType === "linear") {
             // ── LINEAR RESOLVER (из первого скрипта) ──
             let predX, predY;
             if (target.prevX[0] === -1) {
                 predX = target.x;
                 predY = target.y;
             } else {
                 const coef = _calcDistance(myPlayer, target) / MOD.distanceCoefficient + MOD.offsetCoefficient;
                 predX = target.x + coef * (target.x - target.prevX[0]);
                 predY = target.y + coef * (target.y - target.prevY[0]);
             }
             let angle = Math.floor(Math.atan((predY - myPlayer.y) / (predX - myPlayer.x)) * _RAD2DEG);
             if (predX < myPlayer.x) angle += 180;
             this.lastAngle = angle;
             this.cleanAngle = ((angle % 360) + 360) % 360;
             if (MOD.visualizeResolving && MOD.AimBotEnabled) {
                 GetAllTargets.lines[0].reset(myPlayer.x, myPlayer.y, predX, predY);
             } else {
                 GetAllTargets.lines[0].hide();
             }
             return this._applyJitter(angle, this.cleanAngle, myPlayer, target, forFiring);
         }

         if (MOD.resolverType === "trygonometrical") {
             // ── TRIGONOMETRIC RESOLVER (из первого скрипта) ──
             let predX, predY;
             if (target.prevX[0] === -1) {
                 predX = target.x;
                 predY = target.y;
                 if (MOD.visualizeResolving && MOD.AimBotEnabled) {
                     GetAllTargets.lines[0].reset(myPlayer.x, myPlayer.y, predX, predY);
                 }
                 let angle = Math.floor(Math.atan2(target.y - myPlayer.y, target.x - myPlayer.x) * 180 / Math.PI);
                 this.lastAngle = angle;
                 this.cleanAngle = ((angle % 360) + 360) % 360;
                 return this._applyJitter(angle, this.cleanAngle, myPlayer, target, forFiring);
             } else {
                 const speed = Math.sqrt(Math.pow(target.y - target.prevY[0], 2) + Math.pow(target.x - target.prevX[0], 2));
                 const sinA = (target.y - target.prevY[0]) / speed;
                 const cosA = (target.x - target.prevX[0]) / speed;
                 const dist = _calcDistance(myPlayer, target);
                 const angle = Math.floor((Math.atan2(target.y - myPlayer.y, target.x - myPlayer.x) +
                     Math.acos((sinA * (target.x - myPlayer.x) - cosA * (target.y - myPlayer.y)) /
                     (dist * MOD.bulletSpeedCoefficient))) * 180 / Math.PI);
                 const intersection = lineIntersect(
                     target.x, target.y,
                     target.x + (target.x - target.prevX[0]) * 50,
                     target.y + (target.y - target.prevY[0]) * 50,
                     myPlayer.x, myPlayer.y,
                     myPlayer.x + Math.cos(angle * Math.PI / 180) * 3000,
                     myPlayer.y + Math.sin(angle * Math.PI / 180) * 3000
                 );
                 if (MOD.visualizeResolving && MOD.AimBotEnabled && intersection) {
                     GetAllTargets.lines[0].reset(myPlayer.x, myPlayer.y, intersection.x, intersection.y);
                 } else {
                     GetAllTargets.lines[0].hide();
                 }
                 this.lastAngle = angle;
                 this.cleanAngle = ((angle % 360) + 360) % 360;
                 return this._applyJitter(angle, this.cleanAngle, myPlayer, target, forFiring);
             }
         }

         // ── DEFAULT: ULTRA PREDICTION V11 ──
         const predicted = this.predictIterative(target, myPlayer.x, myPlayer.y, 3);

         const rawAngle = Math.atan2(predicted.y - myPlayer.y, predicted.x - myPlayer.x) * (180 / Math.PI);
         this.lastAngle = rawAngle;
         this.cleanAngle = Math.floor(((rawAngle % 360) + 360) % 360);

         let finalAngle = this.cleanAngle;
         if (MOD.smoothAim && this._smoothedAngle !== null && !forFiring) {
             let delta = finalAngle - this._smoothedAngle;
             while (delta > 180) delta -= 360;
             while (delta < -180) delta += 360;
             const sf = Math.max(0.05, Math.min(1.0, MOD.smoothFactor / 10.0));
             this._smoothedAngle = this._smoothedAngle + delta * sf;
             this._smoothedAngle = ((this._smoothedAngle % 360) + 360) % 360;
             finalAngle = Math.round(this._smoothedAngle);
         } else {
             this._smoothedAngle = finalAngle;
         }

         if (MOD.visualizeResolving && MOD.AimBotEnabled) {
             GetAllTargets.lines[0].reset(myPlayer.x, myPlayer.y, predicted.x, predicted.y);
         } else {
             GetAllTargets.lines[0].hide();
         }

         return this._applyJitter(rawAngle, finalAngle, myPlayer, target, forFiring);
     }

     _applyJitter(rawAngle, finalAngle, myPlayer, target, forFiring) {
         if (!MOD.jitterActive) return finalAngle;

         _jitterFrame++;
         const distance = Math.hypot(myPlayer.x - target.x, myPlayer.y - target.y);

         // При стрельбе — уменьшенный джиттер (30%), без стрельбы — полный
         const jitScale = forFiring ? 0.0 : 1.0;
         const maxJit = MOD.jitterOffset * jitScale;

         // stopJittersOnStop check removed for always-on jitter

         let _jitDeg = 0;
         if (MOD.jitterMode === 'sine' || MOD.jitterMode === 'smart') {
             // Smart: при стрельбе — быстрый синус, без стрельбы — медленный
             const speed = MOD.jitterSpeed * 0.08;
             _jitDeg = Math.sin(_jitterFrame * speed) * maxJit;
         } else if (MOD.jitterMode === 'random') {
             _jitDeg = (Math.random() * 2 - 1) * maxJit;
         } else {
             _jitDeg = ((_jitterFrame % 2 === 0) ? 1 : -1) * maxJit;
         }

         return Math.round(rawAngle + _jitDeg);
     }

     findNearestPlayerTo(cords, fov) {
         let closest = null;
         let minDistance = fov;

         const checkEntities = (entities) => {
             for (let entity of entities) {
                 if (!entity.active) continue;
                 if (entity.id === World.PLAYER.id) continue;
                 const worldPlayer = World.players ? World.players[entity.id] : null;
                 if (worldPlayer && worldPlayer.team === World.PLAYER.team && World.PLAYER.team !== -1) continue;
                 const distance = Math.hypot(cords.x - entity.x, cords.y - entity.y);
                 if (distance < minDistance) {
                     closest = entity;
                     minDistance = distance;
                 }
             }
         };

         if (MOD.target === 'players' || MOD.target === 'all') {
             checkEntities(GetAllTargets.players);
         }
         if (MOD.target === 'ghouls' || MOD.target === 'all') {
             checkEntities(GetAllTargets.ghouls);
         }

         return closest;
     }
 }

 class LinesCon {
     constructor(alpha, width, color) {
         this.x1 = -10;
         this.x2 = -10;
         this.y1 = -10;
         this.y2 = -10;
         this.alpha = alpha;
         this.width = width;
         this.color = color;
     }

     reset(x1, y1, x2, y2) {
         this.x1 = x1;
         this.y1 = y1;
         this.x2 = x2;
         this.y2 = y2;
     }

     hide() {
         this.x1 = -10;
         this.y1 = -10;
         this.x2 = -10;
         this.y2 = -10;
