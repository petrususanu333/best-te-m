// ================== ANTI-AIM SYSTEM (из первого скрипта) ==================
class AntiAimCon {
    constructor() {
        this.roflAngle = 0;
        this.roflStep = 1;
        this.jitterStep = false;
        this.mousePressed = false;
        this.initMouseListeners();
    }

    initMouseListeners() {
        document.addEventListener("mousedown", e => {
            if (e.button === 0) this.mousePressed = true;
        });
        document.addEventListener("mouseup", e => {
            if (e.button === 0) this.mousePressed = false;
        });
        document.addEventListener("blur", () => {
            this.mousePressed = false;
        });
    }

    getJitterAngle() {
        if (this.mousePressed) {
            return Aimbot.resolve(true);
        }
        this.jitterStep = !this.jitterStep;
        if (this.jitterStep) {
            return this.getAntiAimAngle() + MOD.jitterOffset;
        } else {
            return this.getAntiAimAngle() - MOD.jitterOffset;
        }
    }

    getAntiAimAngle() {
        if (MOD.antiAimMode === "At target") {
            return Aimbot.resolve(true) + 180;
        }
        if (!this.mousePressed) {
            Aimbot.resolve(true);
        }
        if (MOD.antiAimMode === "Round") {
            this.roflStep++;
            return this.roflAngle += 4 + Math.floor(Math.abs(this.roflStep % 600 - 300) / 12);
        }
        if (MOD.antiAimMode === "Round2") {
            this.roflStep++;
            return Math.floor(this.roflStep % 20 * 18);
        }
        return MOD.antiAimMode;
    }

    setMousePressed(v) { this.mousePressed = v; }
    isMousePressed() { return this.mousePressed; }
}

class AntiAimDodgeCon {
    constructor() {
        this.step = 0;
        this.sequence = [1, 2, 4, 8, 1, 2, 4, 8, 5, 9, 10, 6];
    }

    getMove() {
        this.step += MOD.antiAimCoefficient;
        const idx = Math.floor(this.step / MOD.antiAimCoefficient);
        return this.sequence[idx % this.sequence.length];
    }
}

